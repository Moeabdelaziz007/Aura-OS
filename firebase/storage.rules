rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 📁 AetherOS Agent Files
    match /agents/{userId}/{agentId}/{allPaths=**} {
      allow read: if request.auth != null && 
                     request.auth.uid == userId;
      
      allow write: if request.auth != null && 
                     request.auth.uid == userId &&
                     request.resource.size < 10 * 1024 * 1024 && // 10MB limit
                     request.resource.contentType.matches('application/(json|javascript|python)');
      
      allow delete: if request.auth != null && 
                     request.auth.uid == userId;
    }
    
    // 🧠 AetherOS Memory Files
    match /memory/{userId}/{memoryType}/{allPaths=**} {
      allow read: if request.auth != null && 
                     request.auth.uid == userId;
      
      allow write: if request.auth != null && 
                     request.auth.uid == userId &&
                     request.resource.size < 5 * 1024 * 1024 && // 5MB limit
                     request.resource.contentType.matches('text/(plain|markdown|json)');
      
      allow delete: if request.auth != null && 
                     request.auth.uid == userId;
    }
    
    // 📊 AetherOS Telemetry Data
    match /telemetry/{service}/{allPaths=**} {
      allow read: if request.auth != null && 
                     (request.auth.token.admin == true || 
                      request.auth.token.analyst == true);
      
      allow write: if request.auth != null && 
                     request.resource.size < 1 * 1024 * 1024 && // 1MB limit
                     request.resource.contentType.matches('application/json');
      
      allow delete: if request.auth != null && 
                     request.auth.token.admin == true;
    }
    
    // 🎯 AetherOS Public Assets
    match /public/{allPaths=**} {
      allow read: if true; // Public read access
      
      allow write: if request.auth != null && 
                     request.auth.token.admin == true;
      
      allow delete: if request.auth != null && 
                     request.auth.token.admin == true;
    }
    
    // 🔧 AetherOS Configuration Files
    match /config/{environment}/{allPaths=**} {
      allow read: if request.auth != null;
      
      allow write: if request.auth != null && 
                     request.auth.token.admin == true &&
                     request.resource.size < 100 * 1024; // 100KB limit
      
      allow delete: if request.auth != null && 
                     request.auth.token.admin == true;
    }
    
    // 🛡️ Validation Functions
    function isValidFileName(fileName) {
      return fileName.matches('^[a-zA-Z0-9._-]+$');
    }
    
    function isValidContentType(contentType) {
      return contentType in [
        'application/json',
        'application/javascript',
        'application/python',
        'text/plain',
        'text/markdown',
        'image/png',
        'image/jpeg',
        'image/svg+xml'
      ];
    }
  }
}